programa {
  funcao inicio() {
    real a, b, c, d, soma, div

    escreva("informe um numero: ")
    leia(a)

    escreva("informe um numero: ")
    leia(b)

    escreva("informe um numero: ")
    leia(c)

    escreva("informe um numero: ")
    leia(d)

   soma = a + b + c + d 
   div = soma / 4

   escreva("\nA soma dos números é igual a: ", div)
  }
}
